# Postgres (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+psycopg://liwang:liwang@localhost:5432/liwang
POSTGRES_PASSWORD=liwang

# Web
SESSION_SECRET=change-me-in-prod
RUN_MIGRATIONS_ON_STARTUP=true

# File storage (relative to repo root). Kept separate from `data/` because
# the docker-compose Postgres volume root-owns `data/postgres`.
FILES_ROOT=./var/files

# Embedding (DashScope / Alibaba Cloud)
DASHSCOPE_API_KEY=sk-replace-me
EMBED_MODEL=text-embedding-v3
EMBED_DIM=1024
EMBED_BATCH_SIZE=10
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# LLM (DeepSeek) - reserved for next pass
DEEPSEEK_API_KEY=sk-replace-me

# Per-user defaults
DEFAULT_STORAGE_QUOTA_MB=100

# Demo creds (seed inserts these on first boot when users table is empty):
#   admin / admin
#   alice / alice
#   bob   / bob
#   carol / carol
